# CDN URL for comic page images and videos
# When set, all asset paths will be prefixed with this URL
# Leave empty for local development (serves from /public)
#
# Examples:
#   NEXT_PUBLIC_CDN_URL=https://assets.hangarx.ai
#   NEXT_PUBLIC_CDN_URL=https://your-bucket.r2.cloudflarestorage.com
#
NEXT_PUBLIC_CDN_URL=
